# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=
MINIMAX_API_KEY=

# ─── Kimi 走 Moonshot Platform（推荐）────────────────────────────────
# OpenAI-compatible Chat Completions, token-metered, 任何 OpenAI SDK 都
# 能用。test_astock.py 默认走这条。注册并生成 key：
#   https://platform.moonshot.cn/
# 模型 ID 示例：kimi-k2.6 / kimi-k2-thinking / kimi-k2-turbo-preview
# 配置：
#   config["llm_provider"] = "moonshot"
#   config["deep_think_llm"] = "kimi-k2.6"
MOONSHOT_API_KEY=

# ─── Kimi For Coding（包月，但仅限 Coding Agent 客户端）─────────────
# Anthropic-compatible Bearer auth。服务端会拒非 Coding-Agent 客户端
# （HTTP 403 access_terminated_error）；TradingAgents 走 anthropic SDK
# 路径目前能通过，但属灰区。如果哪天被拒，切回 MOONSHOT_API_KEY 即可。
# 配置：
#   config["llm_provider"] = "anthropic"
#   config["backend_url"]  = "https://api.kimi.com/coding/"
#   config["deep_think_llm"] = "claude-sonnet-4-6"
ANTHROPIC_AUTH_TOKEN=
